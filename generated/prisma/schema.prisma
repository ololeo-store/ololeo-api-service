generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ai_chat_messages {
  id               String           @id
  session_id       String
  sender           String
  message_text     String
  created_at       DateTime         @default(now())
  ai_chat_sessions ai_chat_sessions @relation(fields: [session_id], references: [id])
}

model ai_chat_sessions {
  id                  String             @id
  user_id             String?
  platform            String
  external_session_id String?
  last_intent         String?
  created_at          DateTime           @default(now())
  updated_at          DateTime
  ai_chat_messages    ai_chat_messages[]
  users               users?             @relation(fields: [user_id], references: [id])
}

model categories {
  id          String     @id
  name        String
  slug        String     @unique
  description String?
  created_at  DateTime   @default(now())
  updated_at  DateTime
  products    products[]
}

model gallery_items {
  id           String         @id
  product_id   String?
  image_url    String
  caption      String?
  created_at   DateTime       @default(now())
  products     products?      @relation(fields: [product_id], references: [id])
  social_posts social_posts[]
}

model order_items {
  id             String   @id
  order_id       String
  product_id     String
  quantity       Int
  price_at_order Int
  orders         orders   @relation(fields: [order_id], references: [id])
  products       products @relation(fields: [product_id], references: [id])
}

model orders {
  id             String        @id
  customer_id    String?
  customer       Json?
  pickup_date    DateTime
  notes          String?
  total_price    Int
  status         String        @default("pending")
  payment_status String        @default("unpaid")
  payment_token  String?
  payment_url    String?
  whatsapp_sent  Boolean       @default(false)
  created_at     DateTime      @default(now())
  updated_at     DateTime
  order_items    order_items[]
  users          users?        @relation(fields: [customer_id], references: [id])
  payments       payments[]
}

model payments {
  id             String   @id
  order_id       String
  transaction_id String   @unique
  status         String
  amount         Int
  payment_type   String
  raw_payload    String
  created_at     DateTime @default(now())
  updated_at     DateTime
  orders         orders   @relation(fields: [order_id], references: [id])
}

model products {
  id             String          @id
  category_id    String
  name           String
  slug           String          @unique
  price          Int
  discount_price Int?
  image_url      String?
  description    String?
  stock          Int
  is_active      Boolean         @default(true)
  created_at     DateTime        @default(now())
  updated_at     DateTime
  gallery_items  gallery_items[]
  order_items    order_items[]
  categories     categories      @relation(fields: [category_id], references: [id])
  reviews        reviews[]
  social_posts   social_posts[]
  discounts      discounts[]
}

model reviews {
  id            String    @id
  product_id    String?
  user_id       String?
  customer_name String
  rating        Int
  comment       String?
  is_approved   Boolean   @default(false)
  created_at    DateTime  @default(now())
  products      products? @relation(fields: [product_id], references: [id])
  users         users?    @relation(fields: [user_id], references: [id])
}

model social_posts {
  id                   String         @id
  gallery_item_id      String?
  product_id           String?
  platform             String
  status               String         @default("draft")
  ai_prompt            String?
  ai_generated_caption String?
  media_url            String?
  scheduled_at         DateTime?
  posted_at            DateTime?
  social_post_id       String?
  created_at           DateTime       @default(now())
  updated_at           DateTime
  gallery_items        gallery_items? @relation(fields: [gallery_item_id], references: [id])
  products             products?      @relation(fields: [product_id], references: [id])
}

model store_settings {
  key        String   @id
  value      String
  updated_at DateTime
}

model store_values {
  id          String   @id
  title       String
  icon_name   String
  content     String
  order_index Int
  created_at  DateTime @default(now())
}

model users {
  id               String             @id
  email            String?            @unique
  password_hash    String?
  name             String?
  phone_number     String?
  role             String             @default("customer")
  created_at       DateTime           @default(now())
  updated_at       DateTime
  ai_chat_sessions ai_chat_sessions[]
  orders           orders[]
  reviews          reviews[]
}

model financial_transactions {
  id          String   @id
  type        String // "income" or "expense"
  amount      Int
  description String?
  category    String // e.g. "sales", "purchase", "salary", "operational"
  date        DateTime @default(now())
  created_at  DateTime @default(now())
  updated_at  DateTime
}

model raw_materials {
  id             String   @id
  name           String
  stock          Int      @default(0)
  unit           String // e.g. "pcs", "meter", "roll"
  price_per_unit Int      @default(0)
  created_at     DateTime @default(now())
  updated_at     DateTime
}

model discounts {
  id            String   @id
  product_id    String
  discount_type String // "percentage" or "fixed"
  value         Int
  start_time    DateTime
  end_time      DateTime
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime
  products      products @relation(fields: [product_id], references: [id])
}

model visitor_logs {
  id         String   @id
  ip_address String?
  user_agent String?
  path       String
  created_at DateTime @default(now())
}
